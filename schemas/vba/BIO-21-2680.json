  "x-va-metadata": {
    "status": "bio-reference"
  },
  "definitions": {
    "fullName": {
      "type": "object",
      "properties": {
        "first": {
          "type": "string",
          "maxLength": 12
        },
        "middle": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 1
        },
        "last": {
          "type": "string",
          "maxLength": 18
        }
      }
    },
    "simpleAddress": {
      "type": "object",
      "properties": {
        "street": {
          "type": "string",
          "maxLength": 30
        },
        "street2": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 5
        },
        "city": {
          "type": "string",
          "maxLength": 18
        },
        "state": {
          "type": "string",
          "maxLength": 2
        },
        "postalCode": {
          "type": "string",
          "maxLength": 9
        },
        "country": {
          "type": "string",
          "maxLength": 3
        }
      }
    }
  },
  "properties": {
    "veteranInformation": {
      "type": "object",
      "required": [
        "fullName",
        "ssn",
        "dateOfBirth"
      ],
      "description": "Section I: VETERAN'S IDENTIFICATION INFORMATION",
      "properties": {
        "fullName": {
          "$ref": "#/definitions/fullName"
        },
        "ssn": {
          "type": "string",
          "description": "Social Security Number (9 digits)",
          "pattern": "^\\d{9}$",
          "maxLength": 9,
          "minLength": 9
        },
        "vaFileNumber": {
          "type": "string",
          "description": "VA File Number",
          "maxLength": 9
        },
        "serviceNumber": {
          "type": [
            "string",
            "null"
          ],
          "description": "VETERAN'S SERVICE NUMBER",
          "maxLength": 10
        },
        "dateOfBirth": {
          "type": "string",
          "format": "date",
          "description": "Date of Birth"
        }
      }
    },
    "claimantInformation": {
      "type": "object",
      "required": [
        "fullName",
        "relationship",
        "address"
      ],
      "description": "Section II: CLAIMANT'S IDENTIFICATION INFORMATION",
      "properties": {
        "fullName": {
          "$ref": "#/definitions/fullName"
        },
        "dateOfBirth": {
          "type": "string",
          "format": "date",
          "description": "Date of Birth"
        },
        "ssn": {
          "type": "string",
          "description": "Social Security Number (9 digits)",
          "pattern": "^\\d{9}$",
          "maxLength": 9,
          "minLength": 9
        },
        "relationship": {
          "type": [
            "string",
            "null"
          ],
          "description": "Relationship to veteran",
          "enum": [
            "self",
            "spouse",
            "parent",
            "child"
          ]
        },
        "address": {
          "$ref": "#/definitions/simpleAddress"
        },
        "phoneNumber": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^\\d{10}$",
          "description": "Phone Number",
          "maxLength": 10,
          "minLength": 10
        },
        "internationalPhoneNumber": {
          "type": [
            "string",
            "null"
          ],
          "description": "Phone Number"
        },
        "agreeToElectronicCorrespondence": {
          "type": "boolean"
        },
        "email": {
          "type": [
            "string",
            "null"
          ],
          "description": "Email Address",
          "maxLength": 70
        }
      }
    },
    "benefitInformation": {
      "type": "object",
      "required": [
        "benefitSelection"
      ],
      "description": "SECTION III: CLAIM INFORMATION",
      "properties": {
        "benefitSelection": {
          "type": "string",
          "description": "Type of benefit being claimed",
          "enum": [
            "smc",
            "smp"
          ]
        }
      }
    },
    "additionalInformation": {
      "type": "object",
      "description": "Section IV: IS VETERAN/CLAIMANT HOSPITALIZED?",
      "required": [
        "currentlyHospitalized"
      ],
      "properties": {
        "currentlyHospitalized": {
          "type": "boolean",
          "description": "Is veteran currently hospitalized?"
        },
        "admissionDate": {
          "type": [
            "string",
            "null"
          ],
          "format": "date",
          "description": "Date admitted"
        },
        "hospitalName": {
          "type": [
            "string",
            "null"
          ],
          "description": "Name of hospital"
        },
        "hospitalAddress": {
          "$ref": "#/definitions/simpleAddress"
        }
      }
    },
    "veteranSignature": {
      "type": "object",
      "required": [
        "signature",
        "date"
      ],
      "description": "Section V: CERTIFICATION AND SIGNATURE",
      "properties": {
        "signature": {
          "type": "string",
          "description": "Signature of veteran or claimant"
        },
        "date": {
          "type": "string",
          "format": "date",
          "description": "Date signed (must be within last 60 days)"
        }
      }
    }
  },
  "required": [
    "veteranInformation",
    "benefitInformation",
    "additionalInformation",
    "veteranSignature"
  ]
}